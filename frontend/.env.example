# Frontend Environment Variables
# Copy this file to .env.local for local development (vercel dev reads it)

# Backend API base URL used by the frontend.
# Leave empty on Vercel to use same-origin serverless functions.
VITE_API_BASE_URL=

# Clerk auth
VITE_CLERK_PUBLISHABLE_KEY=pk_test_
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Neon Postgres (Vercel Neon Marketplace)
DATABASE_URL=postgres://user:password@host/db?sslmode=require
POSTGRES_URL=postgres://user:password@host/db?sslmode=require

# ─── Research Pipeline ─────────────────────────────────────────────────────

# Web Search — TAVILY (recommended): https://tavily.com
TAVILY_API_KEY=tvly-

# Or Google Custom Search (fallback): https://programmablesearchengine.google.com
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# LLM — pick one provider, auto-detected
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-

# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-

# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# DeepSeek: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-

# Firecrawl (optional, enables deep page extraction): https://firecrawl.dev
FIRECRAWL_API_KEY=fc-

# Optional Pexels API key for image fetching
VITE_PEXELS_API_KEY=
