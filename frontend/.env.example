# Frontend Environment Variables
# Copy this file to .env.local for local development

# Backend API base URL used by the frontend.
# Leave empty on Vercel to use same-origin serverless functions.
VITE_API_BASE_URL=

# Clerk auth
# Vercel Clerk Marketplace provides NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
# Local Vite development may use either key.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Neon Postgres. Vercel Neon Marketplace usually provides POSTGRES_URL.
DATABASE_URL=postgres://user:password@host/db?sslmode=require
POSTGRES_URL=postgres://user:password@host/db?sslmode=require
FIRECRAWL_API_KEY=

# Optional Pexels API key for image fetching
VITE_PEXELS_API_KEY=YOUR_PEXELS_API_KEY_HERE
