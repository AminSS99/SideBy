# SideBy Environment Variables
# Copy this file to .env.local for local development.
#
# IMPORTANT: For Vercel deployment, set these in Project Settings → Environment Variables.

# ─── Frontend ───────────────────────────────────────────────────────────────

# Vite API base URL. Leave empty on Vercel to use same-origin serverless functions.
VITE_API_BASE_URL=

# Public app URL used for redirects and generated links.
VITE_APP_URL=http://localhost:5173

# Clerk auth (required for authenticated features)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Clerk webhook secret (from Clerk Dashboard → Webhooks → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_

# Clerk invitation redirect URL (optional — defaults to VITE_APP_URL)
CLERK_INVITATION_REDIRECT_URL=

# Optional Pexels API key for image fetching
VITE_PEXELS_API_KEY=

# PostHog analytics (optional)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error tracking (optional)
VITE_SENTRY_DSN=

# ─── Database ─────────────────────────────────────────────────────────────────

# Neon Postgres (required)
# Use the pooled connection string for serverless (ends with ?pgbouncer=true)
# or the standard connection string with sslmode=require.
DATABASE_URL=postgres://user:password@host/db?sslmode=require
POSTGRES_URL=postgres://user:password@host/db?sslmode=require

# Direct/unpooled Neon URL for migrations and schema checks.
DATABASE_URL_UNPOOLED=postgres://user:password@host/db?sslmode=require

# ─── AI Providers (at least one required) ─────────────────────────────────────

# DeepSeek (recommended for Phase 3)
DEEPSEEK_API_KEY=sk-

# OpenRouter (prepared, disabled until key provided)
OPENROUTER_API_KEY=sk-or-

# OpenAI (required for embeddings even if using DeepSeek for LLM)
OPENAI_API_KEY=sk-

# Anthropic
ANTHROPIC_API_KEY=sk-ant-

# Gemini
GEMINI_API_KEY=

# ─── Search / Extraction (at least one search required) ───────────────────────

# Tavily (recommended)
TAVILY_API_KEY=tvly-

# Google Custom Search (fallback)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# Firecrawl (recommended for page extraction — optional but improves quality)
FIRECRAWL_API_KEY=fc-
FIRECRAWL_API_URL=https://api.firecrawl.dev/v2/scrape

# ─── Redis / Upstash (required for rate limits, queues, cache) ────────────────
#
# IMPORTANT: SideBy uses @upstash/redis which requires HTTP REST API URLs.
# Local redis:// URLs will NOT work. Use Upstash or Vercel KV.
#
REDIS_URL=https://your-db.upstash.io
REDIS_TOKEN=your-upstash-rest-api-token

# Vercel KV aliases (alternative to REDIS_URL)
KV_URL=
KV_REST_API_TOKEN=

# ─── File Storage / Knowledge Base ───────────────────────────────────────────

# Vercel Blob read/write token for original knowledge-base uploads.
# Never expose this to the frontend.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_

# Optional backend upload limit override. Defaults to 25MB.
KNOWLEDGE_MAX_UPLOAD_BYTES=26214400

# ─── Scheduled Jobs ───────────────────────────────────────────────────────────

# Required in production for Vercel cron-triggered endpoints.
CRON_SECRET=

# ─── Billing ─────────────────────────────────────────────────────────────────

PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRO_PRICE_ID=
PADDLE_TEAM_PRICE_ID=
PADDLE_ENTERPRISE_PRICE_ID=

# ─── Email (Phase 7 — do not configure yet) ───────────────────────────────────

RESEND_API_KEY=re_

# ─── Observability (optional but recommended) ─────────────────────────────────

SENTRY_DSN=

# PostHog server-side (optional)
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# SnapSolve ecosystem bridge (server-only)
# When both are set, SideBy workspace creation calls SnapSolve Core
# /api/core/v1/workspaces and stores the returned Cockpit workspace id.
SNAPSOLVE_CORE_URL=http://localhost:3000
SNAPSOLVE_SIDEBY_SECRET=

# ─── Slack Integration (optional) ─────────────────────────────────────────────

SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# ─── Rate Limits (optional overrides) ─────────────────────────────────────────

FREE_COMPARISONS_PER_DAY=5
FREE_FOLLOWUPS_PER_DAY=10
FREE_REFRESHES_PER_DAY=3
FREE_EXPORTS_PER_DAY=10
FREE_WATCHLISTS_PER_DAY=5

# ─── Job Guardrails (optional overrides) ──────────────────────────────────────

MAX_JOB_COST_USD=0.50
MAX_JOB_TIME_MS=300000
MAX_SEARCH_CALLS=12
MAX_AI_CALLS=6
